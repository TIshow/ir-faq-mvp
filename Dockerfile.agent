# IR Agent（Python/ADK/FastAPI）を Cloud Run で動かすイメージ。
# ビルド文脈はリポジトリ root（pyproject.toml / uv.lock / agent/ を参照）。
FROM python:3.12-slim

WORKDIR /app

# uv（依存解決）
RUN pip install --no-cache-dir uv

# 依存だけ先に解決（レイヤキャッシュ）
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project

# エージェント本体（agent/data/vis_facts.json も含む＝FACTS_BACKEND=json）
COPY agent ./agent

# Cloud Run は $PORT を注入（既定8080）。0.0.0.0 で listen。
ENV PORT=8080
CMD ["sh", "-c", "uv run --no-sync uvicorn agent.server:app --host 0.0.0.0 --port ${PORT}"]
