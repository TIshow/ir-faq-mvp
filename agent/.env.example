# IR Agent 環境変数（コピーして agent/.env に。Secret は実値をコミットしない）

# --- ADK / Vertex backend ---
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=hallowed-trail-462613-v1
GOOGLE_CLOUD_LOCATION=us-central1

# --- モデル ---
# gemini-3-flash-preview を既定（eval関門: 数値100%/コンプラ0 通過を確認済み）。
# 重要: 実在IDは 'gemini-3-flash-preview'。素の 'gemini-3-flash' は 404。
#       また gemini-3-flash-preview は us-central1 に無く global 提供 → LOCATIONは global。
# ロールバックは MODEL_NAME=gemini-2.5-flash（global でも動作）。
MODEL_NAME=gemini-3-flash-preview

# --- GCP / Discovery Engine ---
# データストアIDは固定しない（リクエストごとに companies.ts の datastoreId を使う）
GCP_PROJECT_ID=hallowed-trail-462613-v1
GCP_LOCATION=global
# Vertex(Gemini) のロケーション。gemini-3-flash-preview は global 提供。
GCP_VERTEX_AI_LOCATION=global

# --- Cloud SQL（層1）---
DB_INSTANCE_CONNECTION_NAME=hallowed-trail-462613-v1:us-central1:ir-faq-db
DB_USER=ir_app_user
DB_NAME=ir_faq
# DB_PASSWORD は Secret Manager から注入する（ここに実値を書かない）
# 例: export DB_PASSWORD=$(gcloud secrets versions access latest --secret=ir-faq-db-password)
DB_PASSWORD=
